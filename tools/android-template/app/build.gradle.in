plugins {
    id 'com.android.application'
}

android {
    namespace "__PACKAGE__"
    compileSdk 35

    defaultConfig {
        applicationId "__PACKAGE__"
        minSdk 26
        targetSdk 35
        versionCode 1
        versionName "1.0"

        ndk {
            abiFilters 'arm64-v8a'
        }

        externalNativeBuild {
            cmake {
                arguments "-DANDROID_STL=c++_shared"
            }
        }
    }

    buildTypes {
        release {
            minifyEnabled false
        }
    }

    externalNativeBuild {
        cmake {
            path 'src/main/cpp/CMakeLists.txt'
        }
    }

    // Include SDL3 Java sources from the ge engine's vendored SDL.
    sourceSets {
        main {
            java.srcDirs = [
                'src/main/java',
                "${rootDir}/__GE_REL__/vendor/github.com/libsdl-org/SDL/android-project/app/src/main/java"
            ]
        }
    }

    lint {
        abortOnError = false
    }
}

// Sync game data + compiled SPIR-V shaders into APK assets before building.
// The host-side build compiles shaders for multiple profiles:
//   build/shaders/           — Metal bytecode (macOS / iOS)
//   build/shaders-spirv/     — SPIR-V (Android Vulkan)
// We consume the SPIR-V variant but place it under assets/build/shaders/
// so the runtime lookup via ge::resource("build/shaders/...") keeps working
// unchanged across platforms.
tasks.register('syncAssets', Sync) {
    from("${rootDir}/../data")                    { into('data') }
    from("${rootDir}/../build/shaders-spirv")     { into('build/shaders') }
    from("${rootDir}/../build/ge/shaders-spirv")  { into('build/ge/shaders') }
    into('src/main/assets')
}
preBuild.dependsOn('syncAssets')

dependencies {
}
