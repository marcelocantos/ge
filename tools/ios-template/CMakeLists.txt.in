# iOS distribution build for __APP_NAME__ — standalone, no ged / player.
#
# Builds the app as a self-contained iOS binary that renders directly via
# bgfx/Metal. Uses the ge engine at ${GE_ROOT}.
cmake_minimum_required(VERSION 3.28)
project(__CMAKE_PROJECT__ LANGUAGES C CXX OBJC OBJCXX)
set(CMAKE_CXX_STANDARD 20)
set(CMAKE_XCODE_LINK_BUILD_PHASE_MODE KNOWN_LOCATION)

get_filename_component(PROJECT_ROOT ${CMAKE_CURRENT_SOURCE_DIR}/.. REALPATH)
get_filename_component(GE_ROOT ${CMAKE_CURRENT_SOURCE_DIR}/__GE_REL__ REALPATH)

# ── bgfx + bx + bimg (vendored, compiled from source for iOS) ───────────
set(BX_DIR   ${GE_ROOT}/vendor/github.com/bkaradzic/bx)
set(BIMG_DIR ${GE_ROOT}/vendor/github.com/bkaradzic/bimg)
set(BGFX_DIR ${GE_ROOT}/vendor/github.com/bkaradzic/bgfx)

add_library(bx STATIC ${BX_DIR}/src/amalgamated.cpp)
target_include_directories(bx PUBLIC
    ${BX_DIR}/include
    ${BX_DIR}/include/compat/ios
)
target_include_directories(bx PRIVATE ${BX_DIR}/3rdparty)
target_compile_options(bx PRIVATE -Wno-unused-but-set-variable)
target_compile_definitions(bx PUBLIC BX_CONFIG_DEBUG=0)

add_library(bimg STATIC
    ${BIMG_DIR}/src/image.cpp
    ${BIMG_DIR}/src/image_gnf.cpp
)
target_include_directories(bimg PUBLIC ${BIMG_DIR}/include)
target_include_directories(bimg PRIVATE
    ${BIMG_DIR}/3rdparty
    ${BIMG_DIR}/3rdparty/astc-encoder/include
)
target_link_libraries(bimg PUBLIC bx)
target_compile_definitions(bimg PRIVATE BIMG_CONFIG_DECODE_ENABLE=0)

# bgfx's amalgamated.cpp needs ObjC++ on Apple platforms (Metal backend).
add_library(bgfx STATIC ${BGFX_DIR}/src/amalgamated.cpp)
set_source_files_properties(${BGFX_DIR}/src/amalgamated.cpp
    PROPERTIES LANGUAGE OBJCXX)
target_include_directories(bgfx PUBLIC ${BGFX_DIR}/include)
target_include_directories(bgfx PRIVATE
    ${BGFX_DIR}/3rdparty
    ${BGFX_DIR}/3rdparty/khronos
    ${BGFX_DIR}/src
)
target_link_libraries(bgfx PUBLIC bx bimg)
target_compile_definitions(bgfx PUBLIC
    BGFX_CONFIG_RENDERER_METAL=1
)

# ── Box2D (vendored C code) ─────────────────────────────────────────────
set(BOX2D_DIR ${GE_ROOT}/vendor/github.com/erincatto/box2d)
file(GLOB BOX2D_SRC ${BOX2D_DIR}/src/*.c)
add_library(box2d STATIC ${BOX2D_SRC})
target_include_directories(box2d PUBLIC  ${BOX2D_DIR}/include)
target_include_directories(box2d PRIVATE ${BOX2D_DIR}/src)

# ── Engine sources (direct-mode subset, no brokered wire path) ──────────
# Mirrors ge/SRC_DIRECT in Module.mk plus the vendor C/C++ sources that
# libge.a normally bundles. No WebSocket / ServerWireBridge / video codec
# — distribution builds never touch the wire.
set(GE_SOURCES
    ${GE_ROOT}/src/Context.cpp
    ${GE_ROOT}/src/Resource.cpp
    ${GE_ROOT}/src/FileIO.cpp
    ${GE_ROOT}/src/FontLoader_apple.mm
    ${GE_ROOT}/src/BgfxContext.mm
    ${GE_ROOT}/src/Signal.cpp
    ${GE_ROOT}/src/SessionHost.mm
    ${GE_ROOT}/src/render/DirectRenderHost.mm
    ${GE_ROOT}/vendor/src/sqlite3.c
    # sqlpipe.cpp embeds the sqlift implementation — do not add sqlift.cpp
    # here or you'll get duplicate-symbol link errors.
    ${GE_ROOT}/vendor/src/sqlpipe.cpp
    ${GE_ROOT}/vendor/src/lz4.c
    ${GE_ROOT}/vendor/github.com/sqliteai/liteparser/src/arena.c
    ${GE_ROOT}/vendor/github.com/sqliteai/liteparser/src/liteparser.c
    ${GE_ROOT}/vendor/github.com/sqliteai/liteparser/src/lp_tokenize.c
    ${GE_ROOT}/vendor/github.com/sqliteai/liteparser/src/lp_unparse.c
    ${GE_ROOT}/vendor/github.com/sqliteai/liteparser/src/parse.c
)

# ── App source files ────────────────────────────────────────────────────
file(GLOB_RECURSE APP_SOURCES
    ${PROJECT_ROOT}/src/*.cpp
    ${PROJECT_ROOT}/src/*.mm
)

add_executable(__CMAKE_PROJECT__ MACOSX_BUNDLE
    ${APP_SOURCES}
    ${GE_SOURCES}
)

# ── Bundle compiled shader blobs ────────────────────────────────────────
# The app's own shaders live in ${PROJECT_ROOT}/build/shaders/*.bin and
# ge's internal render shaders (compose pass) live in
# ${PROJECT_ROOT}/build/ge/shaders/*.bin. Both are mirrored under
# Resources/build/... in the bundle so ge::resource("build/...") resolves
# correctly on-device.
file(GLOB APP_SHADERS
    CONFIGURE_DEPENDS ${PROJECT_ROOT}/build/shaders/*.bin)
file(GLOB GE_RENDER_SHADERS
    CONFIGURE_DEPENDS ${PROJECT_ROOT}/build/ge/shaders/*.bin)
if(APP_SHADERS)
    target_sources(__CMAKE_PROJECT__ PRIVATE ${APP_SHADERS})
    set_source_files_properties(${APP_SHADERS} PROPERTIES
        MACOSX_PACKAGE_LOCATION "Resources/build/shaders")
endif()
if(GE_RENDER_SHADERS)
    target_sources(__CMAKE_PROJECT__ PRIVATE ${GE_RENDER_SHADERS})
    set_source_files_properties(${GE_RENDER_SHADERS} PROPERTIES
        MACOSX_PACKAGE_LOCATION "Resources/build/ge/shaders")
endif()

# main.cpp often needs ObjC++ on iOS for SDL_main.h UIApplication integration.
set_source_files_properties(${PROJECT_ROOT}/src/main.cpp PROPERTIES LANGUAGE OBJCXX)

target_compile_definitions(__CMAKE_PROJECT__ PRIVATE
    ASIO_STANDALONE
    GE_IOS
    GE_DIRECT_ONLY
    SQLITE_ENABLE_SESSION
    SQLITE_ENABLE_PREUPDATE_HOOK
    SQLITE_ENABLE_DESERIALIZE
    BX_CONFIG_DEBUG=0
)

target_include_directories(__CMAKE_PROJECT__ PRIVATE
    ${PROJECT_ROOT}/src
    ${PROJECT_ROOT}/include
    ${GE_ROOT}/include
    ${GE_ROOT}/vendor/include
    ${GE_ROOT}/vendor/github.com/gabime/spdlog/include
    ${GE_ROOT}/vendor/github.com/chriskohlhoff/asio/include
    ${GE_ROOT}/vendor/github.com/libsdl-org/SDL/include
    ${GE_ROOT}/vendor/sdl3/include
    ${GE_ROOT}/vendor/github.com/sqliteai/liteparser/src
)

target_link_libraries(__CMAKE_PROJECT__ PRIVATE bgfx box2d)

# SDL3 prebuilt libraries (iOS device vs simulator).
set(SDL_DEVICE_DIR ${GE_ROOT}/vendor/sdl3/lib/ios-arm64)
set(SDL_SIM_DIR    ${GE_ROOT}/vendor/sdl3/lib/ios-arm64-simulator)

target_link_libraries(__CMAKE_PROJECT__ PRIVATE
    -lSDL3 -lSDL3_image -lSDL3_ttf
    -lfreetype -lharfbuzz -lplutosvg -lplutovg
)

# iOS frameworks needed by SDL3 + bgfx/Metal + CoreMotion.
target_link_libraries(__CMAKE_PROJECT__ PRIVATE
    "-framework Foundation" "-framework UIKit"
    "-framework Metal" "-framework MetalKit"
    "-framework QuartzCore" "-framework IOKit" "-framework IOSurface"
    "-framework CoreGraphics" "-framework CoreServices"
    "-framework CoreFoundation" "-framework CoreBluetooth"
    "-framework CoreMedia" "-framework CoreVideo"
    "-framework AudioToolbox" "-framework AVFoundation"
    "-framework GameController" "-framework CoreHaptics"
    "-framework CoreMotion" "-framework VideoToolbox"
    "-framework Security" "-framework OpenGLES" "-framework ImageIO"
    "-lobjc"
)

set_target_properties(__CMAKE_PROJECT__ PROPERTIES
    MACOSX_BUNDLE_GUI_IDENTIFIER __BUNDLE_ID__
    MACOSX_BUNDLE_BUNDLE_VERSION 1
    MACOSX_BUNDLE_SHORT_VERSION_STRING "1.0"
    MACOSX_BUNDLE_INFO_PLIST ${CMAKE_CURRENT_SOURCE_DIR}/Info.plist
    XCODE_ATTRIBUTE_TARGETED_DEVICE_FAMILY "1,2"
    XCODE_ATTRIBUTE_SUPPORTED_PLATFORMS "iphoneos iphonesimulator"
    XCODE_ATTRIBUTE_PRODUCT_BUNDLE_IDENTIFIER "__BUNDLE_ID__"
    XCODE_ATTRIBUTE_DEVELOPMENT_TEAM "__DEVELOPMENT_TEAM__"
    XCODE_ATTRIBUTE_CODE_SIGN_STYLE "Automatic"
    XCODE_GENERATE_SCHEME TRUE
    XCODE_SCHEME_ENABLE_GPU_API_VALIDATION OFF
    XCODE_ATTRIBUTE_IPHONEOS_DEPLOYMENT_TARGET 16.3
    "XCODE_ATTRIBUTE_LIBRARY_SEARCH_PATHS[sdk=iphoneos*]" "${SDL_DEVICE_DIR}"
    "XCODE_ATTRIBUTE_LIBRARY_SEARCH_PATHS[sdk=iphonesimulator*]" "${SDL_SIM_DIR}"
)
